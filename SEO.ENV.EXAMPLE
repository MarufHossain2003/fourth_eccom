# SEO Implementation - Environment Variables

# Add these to your .env file for SEO configuration

# General
APP_NAME="Amar Jinish BD"
APP_URL="http://localhost:8000"
TWITTER_HANDLE="@yourhandle"

# SEO Configuration (optional - override in config/seo.php if needed)
SEO_SITE_DESCRIPTION="Premium e-commerce platform with quality products"
SEO_SITEMAP_ENABLED=true
SEO_ROBOTS_ENABLED=true
